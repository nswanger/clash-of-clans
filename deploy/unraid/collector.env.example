# Copy this file to collector.env, replace every placeholder, and run chmod 600 collector.env.
# Never commit collector.env or paste its values into logs or screenshots.

CLASH_API_TOKEN=replace-with-server-side-token
CLAN_TAG="#REPLACE"
SUPABASE_URL=https://replace-with-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-server-key
TZ=America/New_York

# Optional. Defaults shown.
LOG_LEVEL=error
ACTIVE_CWL_INTERVAL_MINUTES=60
IDLE_INTERVAL_HOURS=24
