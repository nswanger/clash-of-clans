# Public browser configuration (safe to expose; never use the service-role key here)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_CLAN_TAG=#YOURCLAN
# Use / locally or on a custom/user Pages domain; use /repository-name/ for project Pages.
VITE_BASE_PATH=/

# Collector-only configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CLASH_API_TOKEN=your-clash-api-token
CLAN_TAG=#YOURCLAN
TZ=America/New_York
